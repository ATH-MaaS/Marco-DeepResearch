# ═══════════════════════════════════════════════════════════════
# HSCodeComp Agent — 环境变量配置
# ═══════════════════════════════════════════════════════════════
# 复制本文件为 .env 并填入实际的 API Key 和 Base URL
# 模型路由规则：模型名含 "claude" → Anthropic, 含 "gpt" → OpenAI, 其他 → DashScope

# --- DashScope (qwen3.7-max, glm-5.2, deepseek-v4-pro 等) ---
DASHSCOPE_API_KEY=sk-your-dashscope-api-key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# --- OpenAI / GPT (gpt-5.5 等) ---
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-your-openai-api-key

# --- Anthropic / Claude (claude-opus-4-8 等) ---
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# --- hermes-agent Web Search 配置 ---
# hermes-agent 内置 web 工具支持多种后端，配置方式请参考 hermes-agent 文档：
# - Exa: EXA_API_KEY=your-exa-key
# - Firecrawl: FIRECRAWL_API_KEY=your-firecrawl-key
# - Tavily: TAVILY_API_KEY=your-tavily-key
# 至少配置一个 web search 后端以启用网络搜索功能
